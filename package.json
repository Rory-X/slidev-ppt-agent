{
  "name": "slidev-ppt-agent",
  "version": "0.1.0",
  "description": "One command to give any AI agent the ability to create high-quality Slidev presentations, with built-in preview and one-click publishing.",
  "type": "module",
  "bin": {
    "slidev-ppt-agent": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "assets/",
    "templates/"
  ],
  "scripts": {
    "dev:demo": "slidev --open demo/slides.md",
    "build:demo": "slidev build demo/slides.md --out demo/dist",
    "test": "node --test test/*.test.js",
    "lint": "node --check bin/cli.js src/**/*.js src/commands/*.js",
    "sync:assets": "node scripts/sync-assets.cjs",
    "sync:check": "node scripts/sync-assets.cjs --check",
    "prepublishOnly": "node scripts/sync-assets.cjs"
  },
  "keywords": [
    "slidev",
    "ppt",
    "presentation",
    "ai-agent",
    "cursor",
    "claude-code",
    "codex",
    "slides",
    "deck"
  ],
  "author": "Rory-X",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rory-X/slidev-ppt-agent.git"
  },
  "homepage": "https://github.com/Rory-X/slidev-ppt-agent#readme",
  "dependencies": {
    "commander": "^13.0.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "@inquirer/prompts": "^7.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
